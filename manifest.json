{
  "manifest_version": 3,
  "name": "AGHUse Auto-Print",
  "version": "9.0",
  "description": "Automatiza impressão de etiquetas no AGHUse.",
  "author": "Leonardo Klein Rocha / lklrocha",
  "permissions": [
    "storage"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "content_scripts": [
    {
      "matches": [
        "*://aghuse.hcpa.edu.br/aghu/pages/paciente/etiquetas/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}